# gap_scanner AI 配置示例
# 复制为 .env 并填写真实值
#
# 注意：如果你的 ~/.zshrc 已经设置了 ANTHROPIC_BASE_URL 和
#       ANTHROPIC_AUTH_TOKEN，gap_scanner 会自动复用，无需重复配置。

# --- AI 接入（三选一填写即可）---

# 方式 A：使用 cc.codesome.ai 中转（已在 .zshrc 配置，可省略）
# AI_BASE_URL=https://cc.codesome.ai
# AI_API_KEY=sk-...
# AI_MODEL=claude-3-5-haiku-20241022

# 方式 B：直接使用 OpenAI
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini

# 方式 C：父项目 ModelScope 配置（兼容 OpenAI 格式）
# AI_BASE_URL=https://api-inference.modelscope.cn/v1/
# AI_API_KEY=...
# AI_MODEL=XiaomiMiMo/MiMo-V2-Flash

# --- 词库学习阈值（可选，有默认值）---
# VOCAB_AUTO_ADD_THRESHOLD=0.85   # 置信度 >= 此值自动加入词库
# VOCAB_REVIEW_THRESHOLD=0.60     # 置信度 >= 此值写入 pending_review.txt

# --- AI 请求参数（可选）---
# AI_TIMEOUT=30
# AI_MAX_RETRIES=2
